# PostgreSQL configuration
POSTGRES_USER=sygalin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=sygalin_connect
DATABASE_URL=postgresql://sygalin:change_me@db:5432/sygalin_connect

# Redis configuration
REDIS_URL=redis://redis:6379/0

# FastAPI configuration
SECRET_KEY=change_me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=true
USE_ALEMBIC=true
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://localhost:5174,http://127.0.0.1,http://127.0.0.1:80,http://127.0.0.1:5173
FRONTEND_URL=http://localhost

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# SMS Gateway configuration
SMS_PROVIDER=sandbox
SMS_API_KEY=your_sms_api_key
SMS_API_URL=https://api.sms-provider.com
SMS_SENDER_ID=SYGALIN
SMS_SANDBOX=true
SMS_TIMEOUT_SECONDS=30
SMS_RETRIES=2
SMS_RATE_LIMIT=10

# Frontend environment
VITE_API_URL=http://localhost:8000/api/v1